{
  "name": "inboxreveal",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"next dev\" \"wait-on tcp:3000 && electron .\"",
    "electron:build": "next build && electron-builder",
    "electron:guard:win": "node scripts/ensure-native-windows-build.js",
    "electron:build:win": "npm run electron:guard:win && next build && electron-builder --win --x64 --publish never",
    "electron:build:win:unpacked": "npm run electron:guard:win && next build && electron-builder --win --x64 --dir --publish never"
  },
  "build": {
    "appId": "com.inboxreveal.app",
    "productName": "InboxReveal",
    "asar": false,
    "files": [
      ".next/**",
      "electron/**",
      "node_modules/**",
      "package.json",
      "public/**"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "executableName": "InboxReveal",
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "openai": "^6.32.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
